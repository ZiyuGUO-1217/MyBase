<?xml version="1.0" encoding="UTF-8"?>
<lint>

    <!-- Treat these issues as errors -->
    <issue id="HardcodedText" severity="error" />
    <issue id="NewApi" severity="error" />
    <issue id="WrongThread" severity="error" />
    <issue id="MissingPermission" severity="error" />

    <!-- Treat these issues as warnings -->
    <issue id="UnusedResources" severity="warning" />
    <issue id="IconMissingDensityFolder" severity="warning" />
    <issue id="ContentDescription" severity="warning" />
    <issue id="RtlHardcoded" severity="warning" />
    <issue id="KeyboardInaccessibleWidget" severity="warning" />

    <!-- Keep CI stable when hosted runners install a newer Android SDK before the project intentionally retargets. -->
    <issue id="OldTargetApi" severity="ignore" />

    <!-- Disable dependency version checks in CI; they require remote metadata and are not code-quality failures. -->
    <issue id="AndroidGradlePluginVersion" severity="ignore" />
    <issue id="GradleDependency" severity="ignore" />
    <issue id="NewerVersionAvailable" severity="ignore" />
</lint>
